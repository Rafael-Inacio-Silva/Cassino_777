PORT=3001
NODE_ENV=development

# Banco de dados
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inacios777
DB_USER=seu_usuario_postgres
DB_PASSWORD=sua_senha_postgres

# JWT
JWT_SECRET=chave_super_secreta_troque_em_producao
JWT_EXPIRES_IN=7d

# Frontend
FRONTEND_URL=http://localhost:5173

# Limites de mesa por rodada (em R$)
ROULETTE_MIN_BET=1
ROULETTE_MAX_BET=10000
BLACKJACK_MIN_BET=1
BLACKJACK_MAX_BET=5000

# ─────────────────────────────────────────────────
# Google OAuth — obter em: console.cloud.google.com
# Deixe vazio para desativar o login com Google
# ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─────────────────────────────────────────────────
# E-mail SMTP (verificação de conta) — ex.: Brevo
# Sem SMTP_HOST, usa Ethereal (caixa de teste em dev)
# ─────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="inacios777 <nao-responda@seudominio.com.br>"
